<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ name }} - Documentation</title>
    <style>
        body { font-family: -apple-system, sans-serif; padding: 2rem; max-width: 1200px; margin: 0 auto; color: #19191c; line-height: 1.6; }
        a { color: #2762df; text-decoration: none; }
        a:hover { text-decoration: underline; }
        .ContentGroup { margin-bottom: 1.5rem; }
        .ContentDivergentInstance { background: #f4f5f7; padding: 1rem; margin-bottom: 1rem; border-radius: 5px; font-family: monospace; }
        table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
        th, td { border: 1px solid #d1d5db; padding: 0.75rem; text-align: left; vertical-align: top; }
        th { background: #f9fafb; font-weight: 600; width: 30%; }
        pre { background: #f4f5f7; padding: 1rem; overflow-x: auto; border-radius: 5px; }
        code { font-family: "JetBrains Mono", monospace; font-size: 0.9em; }
        .RowTitle { font-weight: bold; }
    </style>
</head>
<body>
    <main>
        {# Pass the root content tree directly into the recursive component #}
        {% include "/Users/alex/ADFA/Misc Software/Pebble Templating/kdoc-pebble-processing/templates/content_node.pebble" with {"node": content} %}
    </main>
</body>
</html>